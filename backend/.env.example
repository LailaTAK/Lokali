# backend/.env.example

# --- SYSTEM CONFIGURATION ---
PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:19006,http://localhost:8081

# --- DATABASE & CACHE CONNECTION ---
# PostgreSQL database connection URL for host-side commands such as Prisma migrate.
# The Docker backend service overrides this internally to use postgres:5432.
DATABASE_URL="postgresql://lokali:lokali_secret@localhost:5432/lokali_db?schema=public"

# Redis connection URL for host-side commands.
# The Docker backend service overrides this internally to use redis:6379.
REDIS_URL="redis://localhost:6379"

# --- SECURITY & AUTHENTICATION ---
# Random secret key string used for signing JWT access tokens (min 32 chars recommended)
JWT_SECRET="your_jwt_access_token_signature_secret_key"

# Random secret key string used for signing JWT refresh tokens
JWT_REFRESH_SECRET="your_jwt_refresh_token_signature_secret_key"

# Lifetime duration of JWT access tokens
JWT_EXPIRES_IN="15m"

# Lifetime duration of JWT refresh tokens
JWT_REFRESH_EXPIRES_IN="7d"

# --- CLOUD STORAGE (AWS S3) ---
# S3 Credentials
AWS_ACCESS_KEY_ID="your_aws_iam_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_iam_secret_access_key"

# Target S3 bucket name
AWS_S3_BUCKET="lokali-assets-bucket"

# Target S3 region code
AWS_REGION="us-east-1"

# --- EMAIL SERVICE (SENDGRID) ---
# SendGrid API authorization key
SENDGRID_API_KEY="SG.your_sendgrid_api_key_goes_here"

# Authorized sender email address
SENDGRID_FROM="no-reply@lokali.com"

# --- GEOLOCATION SERVICES (MAPBOX) ---
# Mapbox Places API token
MAPBOX_TOKEN="pk.your_mapbox_public_or_secret_access_token"

# --- OBSERVABILITY & MONITORING ---
# Sentry server integration DSN url
SENTRY_DSN="https://your_sentry_public_key@o0.ingest.sentry.io/your_project_id"

# Logtail Winston transport token
LOGTAIL_TOKEN="your_logtail_source_token"

# --- MOBILE PUSH NOTIFICATIONS (FIREBASE) ---
# Firebase service account credential fields (stringified JSON payload).
# Leave empty in local development to use mock push notifications.
FIREBASE_SERVICE_ACCOUNT=

# --- PAYMENT INTEGRATIONS (STRIPE / WAVE / OM) ---
# Stripe Account secret API key
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"

# Stripe Webhook verification key
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_signing_secret"

# Wave Mobile Money webhook validation key
WAVE_WEBHOOK_SECRET="your_wave_webhook_hmac_signing_secret"

# Orange Money webhook notification token
ORANGE_MONEY_WEBHOOK_TOKEN="your_orange_money_webhook_token_signature"
