# Physical Android phone connected with USB + adb reverse:
# adb reverse tcp:5000 tcp:5000
EXPO_PUBLIC_API_URL=http://127.0.0.1:5000/api

# Android emulator talking to the backend exposed on the host machine:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# For a physical phone on the same Wi-Fi, use your PC IPv4 instead.
# Example:
# EXPO_PUBLIC_API_URL=http://192.168.1.25:5000/api

# Required by react-native-maps on Android.
# Create a Google Maps Platform key with "Maps SDK for Android" enabled.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=DUMMY_GOOGLE_MAPS_API_KEY
